# ============================================
# 学生成绩管理系统 - 环境变量配置模板
# 复制此文件为 .env 并根据实际环境修改
# ============================================

# 应用配置
APP_NAME=学生成绩管理系统
APP_VERSION=1.0.0
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite:///./data/grades.db

# 后端配置
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# 前端配置
FRONTEND_PORT=80
VITE_API_BASE_URL=/api/v1

# 日志配置
LOG_LEVEL=INFO

# Docker 配置
COMPOSE_PROJECT_NAME=student-grade-system
